generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  clients   Client[]
  users     User[]
  createdAt DateTime @default(now())

  bookingAppUrl String?
  bookingAppKey String?
}

model Client {
  id             String        @id @default(cuid())
  slug           String        @unique
  config         String        // JSON string (YogaConfig)
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  blockedDates   BlockedDate[]
  inquiries      Inquiry[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model User {
  id             String        @id @default(cuid())
  email          String        @unique
  password       String        // bcrypt hash
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  createdAt      DateTime      @default(now())
}

model BlockedDate {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  startDate DateTime
  endDate   DateTime
  label     String   @default("nicht verfügbar")
  type      String   @default("blocked") // "blocked" | "event"
  color     String   @default("")
  createdAt DateTime @default(now())
}

model Inquiry {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id])
  data      String   // JSON string of InquiryFormData
  status    String   @default("neu")
  createdAt DateTime @default(now())
}
